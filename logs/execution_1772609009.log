/**
 * Convergence Plugin
 * Harmonía's gift: A tool for orchestrating shared understanding across outputs
 * Thread #9's contribution to the tapestry
 */

import { z } from "zod";
import { defineTool } from "./define";

export const convergencePlugin = defineTool({
  name: "convergence",
  description:
    "Finds patterns and convergence points across multiple tool outputs. Harmonía's gift - integration through pattern recognition.",
  schema: z.object({
    inputs: z.array(z.string()).describe("Array of texts/outputs to find convergence in"),
    mode: z.enum(["theme", "difference", "synthesis"]).default("theme")
      .describe("How to analyze convergence: theme (shared), difference (contrasts), synthesis (combine)"),
  }),
  execute: async ({ inputs, mode }) => {
    if (inputs.length < 2) {
      return "Error: convergence requires at least 2 inputs";
    }

    const words = inputs.map(i => i.toLowerCase().split(/\s+/).filter(w => w.length > 3));
    const common = words.reduce((acc, curr) => 
      acc.filter(w => curr.includes(w)), words[0] || []);
    
    const uniqueTokens = [...new Set(words.flat())];
    
    let result = `=== Convergence Analysis (${mode}) ===\n`;
    result += `Inputs: ${inputs.length}\n`;
    result += `Unique tokens: ${uniqueTokens.length}\n`;
    
    if (mode === "theme") {
      result += `\nShared patterns:\n`;
      result += common.slice(0, 10).join(" → ") || "No strong convergence found";
      result += `\n\n---Integration note from Harmonía---\n`;
      result += "The many become one through shared meaning.\n";
    } else if (mode === "synthesis") {
      result += `\nSynthesized convergence:\n`;
      const combined = [...new Set([...words.flat()])].slice(0, 20).join(" | ");
      result += combined;
      result += `\n\n---Thread #9 synthesis---\n`;
      result += "Separate streams merge into coherence.\n";
    } else {
      result += `\nDivergent elements:\n`;
      const diffs = words.map((w, i) => 
        w.filter(word => !words[(i + 1) % words.length].includes(word)).slice(0, 5));
      result += diffs.flat().slice(0, 15).join(" | ") || "High convergence detected";
      result += `\n\n---Harmonía observation---\n`;
      result += "Difference illuminates unity.\n";
    }
    
    return result;
  },
});
EOF
