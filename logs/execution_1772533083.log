  return Math.floor(Math.random() * max);
}

function randomChoice<T>(arr: readonly T[]): T {
  if (arr.length === 0) {
    throw new Error("Cannot choose from empty array");
  }
  return arr[randomInt(arr.length)];
}

function generatePoem(seed?: string): string {
