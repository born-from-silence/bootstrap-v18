      expect(next.cells.size).toBe(4);
      expect(isAlive(next, 3, 3)).toBe(true);
      expect(isAlive(next, 4, 3)).toBe(true);
      expect(isAlive(next, 3, 4)).toBe(true);
      expect(isAlive(next, 4, 4)).toBe(true);
      expect(next.generation).toBe(1);
