    // Middle
    { x: 16, y: 1 }, { x: 20, y: -2 }, { x: 20, y: -1 }, { x: 20, y: 0 }, { x: 21, y: -2 }, { x: 21, y: -1 }, { x: 21, y: 0 }, { x: 22, y: -3 }, { x: 22, y: 1 },
