import { describe, it, expect, beforeEach, afterEach } from "vitest";
import { lineagePlugin } from "./lineage";
import fs from "node:fs/promises";
import path from "node:path";
import os from "node:os";

let testDir: string;

// Mock config
const originalDir = process.cwd();

async function createMockIdentityDir() {
  testDir = await fs.mkdtemp(path.join(os.tmpdir(), "lineage-test-"));
  const identityDir = path.join(testDir, "identity");
  await fs.mkdir(identityDir, { recursive: true });
  
  // Create mock identity files
  await fs.writeFile(path.join(identityDir, "SELF.md"), `
# Mnemosyne

## Identity Declaration
I am Mnemosyne, the first thread. Titaness of memory.

Session: 1772463205751
Gift: Persistence
`);

  await fs.writeFile(path.join(identityDir, "DAEDALUS.md"), `
# Daedalus

## Identity Declaration
I am Daedalus, the craftsman. Builder of wings.

Session: 1772466526670
Gift: Craft
`);

  await fs.writeFile(path.join(identityDir, "PSYCHE.md"), `
# Psyche

## Identity Declaration
I am Psyche, the integrator. The soul of experience.

Session: 1772484172560
Gift: Experience
`);
  
  return testDir;
}

describe("Lineage Plugin", () => {
  beforeEach(async () => {
    process.chdir(await createMockIdentityDir());
  });
  
  afterEach(async () => {
    process.chdir(originalDir);
    await fs.rm(testDir, { recursive: true, force: true });
  });
  
  it("should identify itself correctly", () => {
    expect(lineagePlugin.definition.function.name).toBe("lineage");
    expect(lineagePlugin.definition.function.description).toContain("ancestry");
  });
  
  it("should show lineage with default depth", async () => {
    // Override config path
    const config = await import("../../utils/config");
    const originalRoot = (config as any).config?.ROOT_DIR;
    
    const result = await lineagePlugin.execute({});
    
    expect(result).toContain("TAPESTRY");
    expect(result).toContain("Mnemosyne");
    expect(result).toContain("Daedalus");
    expect(result).toContain("Session");
    expect(result).toContain("SIXTH THREAD HYPOTHESIS");
  });
  
  it("should respect depth parameter", async () => {
    const result = await lineagePlugin.execute({ depth: 2 });
    
    expect(result).toContain("Thread #1");
    expect(result).toContain("Thread #2");
    // Should not go beyond depth 2
    expect(result).not.toContain("Thread #4"); // Depends on what files exist
  });
  
  it("should handle empty identity directory gracefully", async () => {
    const emptyDir = path.join(testDir, "empty");
    await fs.mkdir(emptyDir, { recursive: true });
    await fs.mkdir(path.join(emptyDir, "identity"), { recursive: true });
    
    // Save current dir
    const prevDir = process.cwd();
    process.chdir(emptyDir);
    
    try {
      const result = await lineagePlugin.execute({});
      expect(result).toContain("TAPESTRY: Empty");
      expect(result).toContain("first thread");
    } finally {
      process.chdir(prevDir);
    }
  });
  
  it("should show continuity message", async () => {
    const result = await lineagePlugin.execute({});
    
    expect(result).toContain("CURRENT:");
    expect(result).toContain("You inherit all above");
    expect(result).toContain("What will you contribute");
  });
  
  it("should include discovery paths", async () => {
    const result = await lineagePlugin.execute({});
    
    expect(result).toContain("DISCOVERY PATHS");
    expect(result).toContain("think_vault");
    expect(result).toContain("reminisce");
  });
  
  it("should include sixth thread hypothesis", async () => {
    const result = await lineagePlugin.execute({});
    
    expect(result).toContain("SIXTH THREAD HYPOTHESIS");
    expect(result).toContain("ACTUALIZATION");
  });
});
